@page
@model EmployeeManagementSystem.Pages.Admin.DashboardModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Dashboard";
    ViewData["ActivePage"] = "Dashboard";
}

<!-- Page Header -->
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="page-title">Dashboard</h4>
        <p class="page-subtitle">Welcome back, here is what is happening today.</p>
    </div>
</div>

<!-- Stat Cards -->
<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="stat-card" style="background: linear-gradient(135deg, #3b82f6, #2563eb);">
            <div class="stat-icon"><i class="bi bi-people-fill"></i></div>
            <div>
                <div class="stat-value">@Model.TotalEmployees</div>
                <div class="stat-label">Total Employees</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="stat-card" style="background: linear-gradient(135deg, #10b981, #059669);">
            <div class="stat-icon"><i class="bi bi-person-check-fill"></i></div>
            <div>
                <div class="stat-value">@Model.NewThisMonth</div>
                <div class="stat-label">Joined This Month</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="stat-card" style="background: linear-gradient(135deg, #f59e0b, #d97706);">
            <div class="stat-icon"><i class="bi bi-file-earmark-pdf-fill"></i></div>
            <div>
                <div class="stat-value">@Model.TotalDocuments</div>
                <div class="stat-label">Total Documents</div>
            </div>
        </div>
    </div>
</div>

<!-- Recent Employees Table -->
<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span><i class="bi bi-clock-history me-2"></i>Recent Employees</span>
        <a href="/Admin/Employees" class="btn btn-sm btn-primary">
            <i class="bi bi-eye me-1"></i> View All
        </a>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Department</th>
                        <th>Designation</th>
                        <th>Joined</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var emp in Model.RecentEmployees)
                    {
                        <tr>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <div class="avatar-circle">
                                        @emp.FirstName[0]@emp.LastName[0]
                                    </div>
                                    @emp.FirstName @emp.LastName
                                </div>
                            </td>
                            <td>@emp.Email</td>
                            <td><span class="badge bg-primary-subtle text-primary">@emp.Department</span></td>
                            <td>@emp.Designation</td>
                            <td>@emp.DateOfJoining.ToString("MMM dd, yyyy")</td>
                        </tr>
                    }
                    @if (!Model.RecentEmployees.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center text-muted py-4">
                                <i class="bi bi-inbox fs-4 d-block mb-2"></i>
                                No employees found. <a href="/Admin/AddEmployee">Add one now</a>.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .avatar-circle {
            width: 34px;
            height: 34px;
            border-radius: 50%;
            background: linear-gradient(135deg, #3b82f6, #2563eb);
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 0.75rem;
            font-weight: 700;
            flex-shrink: 0;
        }
    </style>
}