<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Employee Management System</title>

    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet" />
    <!-- DataTables -->
    <link href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css" rel="stylesheet" />
    <!-- Custom Styles -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

    @if (User.Identity != null && User.Identity.IsAuthenticated)
    {
        <div class="d-flex" id="wrapper">

            <!-- ─── Sidebar ─────────────────────────────────────────────── -->
            <nav id="sidebar" class="d-flex flex-column p-3">
                <a href="/" class="sidebar-brand mb-4">
                    <i class="bi bi-people-fill me-2"></i>
                    <span>EMS</span>
                </a>

                <ul class="nav flex-column gap-1">
                    @if (User.IsInRole("Admin"))
                    {
                        <li class="nav-item">
                            <a class="nav-link sidebar-link @(ViewData["ActivePage"]?.ToString() == "Dashboard" ? "active" : "")"
                                   href="/Admin/Dashboard">
                                <i class="bi bi-speedometer2 me-2"></i> Dashboard
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link sidebar-link @(ViewData["ActivePage"]?.ToString() == "Employees" ? "active" : "")"
                                   href="/Admin/Employees">
                                <i class="bi bi-person-lines-fill me-2"></i> Employees
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link sidebar-link @(ViewData["ActivePage"]?.ToString() == "AddEmployee" ? "active" : "")"
                                   href="/Admin/AddEmployee">
                                <i class="bi bi-person-plus-fill me-2"></i> Add Employee
                            </a>
                        </li>
                    }
                    @if (User.IsInRole("Employee"))
                    {
                        <li class="nav-item">
                            <a class="nav-link sidebar-link @(ViewData["ActivePage"]?.ToString() == "Profile" ? "active" : "")"
                                   href="/Employee/Profile">
                                <i class="bi bi-person-circle me-2"></i> My Profile
                            </a>
                        </li>
                    }
                </ul>

                <!-- ─── Logout at bottom of sidebar ──────────────────────── -->
                <div class="mt-auto">
                    <form method="post" action="/Auth/Logout">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-outline-light w-100">
                            <i class="bi bi-box-arrow-left me-2"></i> Logout
                        </button>
                    </form>
                </div>
            </nav>

            <!-- ─── Main Content ─────────────────────────────────────────── -->
            <div id="page-content" class="flex-grow-1">

                <!-- Top Navbar -->
                <nav class="navbar top-navbar px-4">
                    <span class="navbar-text fw-semibold">
                        <i class="bi bi-person-circle me-2"></i>
                        Welcome, @User.Identity.Name
                    </span>
                </nav>

                <!-- Page Body -->
                <div class="content-area p-4">
                    @RenderBody()
                </div>
            </div>

        </div>
    }
    else
    {
        <!-- Public pages (Login) — no sidebar -->
        @RenderBody()
    }

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <!-- jQuery -->
    <script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>
    <!-- DataTables -->
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>
    <!-- SweetAlert2 -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>